# --- Required ---
# Postgres (use Supabase Pooled connection string for prod, asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sentinellm

# Redis (Upstash for prod; local for dev)
REDIS_URL=redis://localhost:6379/0

# HuggingFace model repo to load the classifier from
HF_MODEL_REPO=your-user/sentinellm-v1

# --- Optional ---
# Path to local ONNX file. If unset, predictor downloads the .onnx from HF_MODEL_REPO
ONNX_MODEL_PATH=models/sentinellm.onnx

# Cache TTL in seconds for exact-match Redis cache
CACHE_TTL_SECONDS=86400

# Toxicity threshold above which a prediction is "flagged"
FLAG_THRESHOLD=0.7

# Log level
LOG_LEVEL=INFO

# --- Synthetic data generation only (scripts/generate_synthetic.py) ---
# Free tier key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
